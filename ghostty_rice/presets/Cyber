# ╔══════════════════════════════════════════════════════════════╗
# ║  Cyber — Neon-lit cyberpunk vibes for the terminal hacker    ║
# ╚══════════════════════════════════════════════════════════════╝
#
# High transparency with a holographic icon. This profile pushes the
# glass effect to its limits — your desktop wallpaper bleeds through,
# creating an immersive, futuristic workspace. The hidden titlebar
# maximizes screen real estate for a distraction-free hacking session.
#
# Best paired with: Hack Nerd Font, JetBrains Mono NL, or IBM Plex Mono
# Tip: Use a dark, neon-themed wallpaper for the best glass effect.

# --- Theme ---
theme = Catppuccin Macchiato

# --- Window ---
# Aggressive transparency for the cyberpunk glass effect
background-opacity = 0.82
background-blur = macos-glass-clear
window-padding-x = 16
window-padding-y = 12
window-padding-color = extend

# --- Titlebar ---
# Hidden titlebar for maximum immersion
macos-titlebar-style = hidden
macos-icon = holographic

# --- Cursor ---
cursor-style = block
cursor-style-blink = true
cursor-color = cell-foreground
cursor-text = cell-background

# --- Selection ---
selection-background = #494d64
selection-foreground = #cad3f5

# --- Splits ---
unfocused-split-opacity = 0.70

# --- Accessibility ---
minimum-contrast = 4.5
