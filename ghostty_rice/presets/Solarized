# ╔══════════════════════════════════════════════════════════════╗
# ║  Solarized — Precision colors for machines and people       ║
# ╚══════════════════════════════════════════════════════════════╝
#
# The scientifically engineered color scheme by Ethan Schoonover.
# Solarized uses carefully chosen CIELAB lightness relationships and
# a unique set of sixteen colors designed for both light and dark modes.
# Auto-switches between Solarized Dark and Light based on system setting.
#
# Best paired with: Inconsolata, Droid Sans Mono, or Ubuntu Mono

# --- Theme (auto light/dark switching) ---
theme = light:Solarized Light,dark:Solarized Dark

# --- Window ---
# Near-opaque to preserve Solarized's precise color relationships
background-opacity = 0.96
background-blur = macos-glass-regular
window-padding-x = 14
window-padding-y = 10
window-padding-color = extend

# --- Titlebar ---
macos-titlebar-style = transparent
macos-icon = glass

# --- Cursor ---
cursor-style = block
cursor-style-blink = true
cursor-color = cell-foreground
cursor-text = cell-background

# --- Selection ---
# Solarized base01 for selection
selection-background = #586e75
selection-foreground = #fdf6e3

# --- Splits ---
unfocused-split-opacity = 0.85

# --- Accessibility ---
minimum-contrast = 4.5
