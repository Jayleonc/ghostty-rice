#
# Design philosophy: A designer's atelier at golden hour.
#
# Rosé Pine's palette draws from natural pigments — muted golds,
# dusty roses, and pine-green undertones. It's the only popular
# theme that feels handcrafted rather than computed.
#
# Color psychology: Muted, desaturated tones invoke calm and focus
# (the "library effect"). The warmth of gold (#f6c177) as accent
# triggers the brain's reward pathway — a subtle "highlight" that
# feels earned, not shouted.
#
# Visual reference: Terrence Malick's "The Tree of Life" — soft
# light through curtains, everything bathed in warmth, never harsh.
#
# Best paired with: Maple Mono, Berkeley Mono, or Inter Mono

# --- Theme (auto light/dark switching) ---
theme = light:Rose Pine Dawn,dark:Rose Pine

# --- Window ---
# Rosé Pine's muted tones tolerate a touch more glass than
# high-contrast themes — the blur adds a watercolor quality.
background-opacity = 0.95
background-blur = macos-glass-regular
window-padding-x = 18
window-padding-y = 14
window-padding-color = extend

# --- Titlebar ---
macos-titlebar-style = transparent
macos-icon = glass

# --- Cursor ---
# Slim bar, gentle blink — like a candle flame in a quiet room.
cursor-style = bar
cursor-style-blink = true

# --- Selection ---
# Highlight-med (#44415a) — a gentle veil, not a highlighter pen.
selection-background = #44415a
selection-foreground = #e0def4

# --- Splits ---
unfocused-split-opacity = 0.80

# --- Accessibility ---
minimum-contrast = 4.5
