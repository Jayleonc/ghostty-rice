# ╔══════════════════════════════════════════════════════════════╗
# ║  Tokyo Night — Lost in Translation                           ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Design philosophy: 3 AM in Shinjuku, the city glowing below.
#
# Tokyo Night's deep navy base (#1a1b26) is NOT black — it carries
# a blue-violet undertone that makes neon accents (cyan, magenta,
# blue) pop like signage reflected in wet pavement. The palette
# is optimized for modern syntax highlighting: JSX/TSX, Rust, and
# Go all look exceptional because the accent distribution avoids
# the "everything is blue" trap of other dark-blue themes.
#
# Color psychology: Deep blue backgrounds trigger the circadian
# system less aggressively than pure black, making this an ideal
# late-night coding theme. The warm accent (#ff9e64 for strings)
# creates focal hierarchy — your eye finds the data naturally.
#
# Visual reference: Sofia Coppola's "Lost in Translation" —
# neon-washed melancholy, city lights through hotel glass.
#
# Best paired with: Cascadia Code, Fira Code, or Monaspace Argon

# --- Theme ---
theme = TokyoNight

# --- Window ---
# Slight glass effect to suggest "looking through a window at
# the city below." More transparency than Catppuccin because
# Tokyo Night's blue base blends better with most wallpapers.
background-opacity = 0.94
background-blur = macos-glass-regular
window-padding-x = 16
window-padding-y = 12
window-padding-color = extend

# --- Titlebar ---
macos-titlebar-style = transparent
macos-icon = glass

# --- Cursor ---
# Bar cursor with gentle blink — like a distant signal light.
cursor-style = bar
cursor-style-blink = true

# --- Selection ---
# Deep selection blue — like neon reflected on dark glass.
selection-background = #33467c
selection-foreground = #c0caf5

# --- Splits ---
unfocused-split-opacity = 0.75

# --- Accessibility ---
minimum-contrast = 4.5
